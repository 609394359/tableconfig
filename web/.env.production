# 线上环境

# 变量必须以 VITE_ 为前缀才能暴露给外部读取
NODE_ENV = 'production'

# API请求前缀
# VITE_APP_BASE_API = '/pro-api'
VITE_APP_BASE_API = 'https://table.api.yqdll.cn/' 

# proxy代理配置
# VITE_APP_TARGET_URL = 'http://127.0.0.1:15000/' 
VITE_APP_TARGET_URL = 'https://table.api.yqdll.cn/' 
VITE_APP_TARGET_BASE_API = ''